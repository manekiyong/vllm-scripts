DOCKER_IMAGE=vllm/vllm-openai
DOCKER_VERSION=v0.17.0
MODEL_NAME=Qwen3-Omni-30B-A3B-Instruct
HEAD_NODE_ADDRESS= # ONLY USED IF NODE_TYPE = WORKER
SELF_NODE_ADDRESS= # NODE IP ADDRESS
NODE_TYPE=head  # Should be --head or --worker


NFS_VOL_NAME=models
NFS_LOCAL_MNT=/models
NFS_SERVER= # NAS IP ADDRESS
NFS_SHARE=/nas/path/to/models
NFS_OPTS=vers=4,soft